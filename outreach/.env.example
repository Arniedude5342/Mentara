# Copy this file to ".env" (same folder) and fill in your values.
# ".env" is gitignored — never commit your real credentials.

# --- Gmail (sending) ---
# Use a Gmail APP PASSWORD, not your normal password.
# Requires 2-Step Verification ON, then create one at:
#   https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=reacharnavmalhotra@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_NAME=Arnav Malhotra
# Optional: where replies should go (defaults to GMAIL_ADDRESS if blank)
REPLY_TO=

# --- Notion ---
# Create an internal integration -> copy the token -> then SHARE the
# "Mentor & Company Outreach" database with that integration (... menu ->
# Connections -> your integration). Steps in README.md.
#   https://www.notion.so/profile/integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Already filled in for you — this is your outreach database id:
NOTION_DB_ID=6b87c22a1c204bec80cc8146cb92a9d5

# --- Sending safety (conservative defaults; raise slowly as you warm up) ---
DAILY_CAP=25
FOLLOWUP1_DAYS=3
FOLLOWUP2_DAYS=5
MIN_DELAY_SEC=45
MAX_DELAY_SEC=150

# Reply / opt-out auto-detection over IMAP (recommended ON for compliance)
CHECK_REPLIES=true
IMAP_HOST=imap.gmail.com

# The engine creates DRAFTS by default (review + send by hand in Gmail).
# This is the Gmail Drafts mailbox name; only change it if your Gmail is in
# another language (e.g. "[Google Mail]/Drafts" on some older accounts).
DRAFTS_FOLDER=[Gmail]/Drafts

# Optional CAN-SPAM footer line (a mailing address makes you look legit)
PHYSICAL_ADDRESS=

# Optional cron guard: only auto-send between these hours (24h, local time).
# Leave blank to allow any time. Example: 9 and 17 = 9am–5pm only.
SEND_WINDOW_START=
SEND_WINDOW_END=
