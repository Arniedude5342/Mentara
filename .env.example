# Supabase — get these from your Supabase project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini API — get from https://aistudio.google.com/app/apikey (free tier)
GOOGLE_API_KEY=your-google-api-key-here

# Google Calendar OAuth — iOS Client ID from Google Cloud Console
# Enable Calendar API → OAuth Consent Screen → add scope calendar.events
# Use the same project as your Supabase Google OAuth
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id-here

# Sentry — get from sentry.io → your project → Settings → Client Keys
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
